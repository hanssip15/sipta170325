APP_NAME=Sipta
APP_ENV=development #change to local if u running in local env
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=database # This is the name of the service in docker-compose.yml
DB_PORT=3306 # This is the default port for MySQL, see docker-compose.yml, use port in the right side
DB_DATABASE=sipta
DB_USERNAME=siptadb
DB_PASSWORD=secret

RUN_SEEDER=true